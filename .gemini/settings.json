{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    }
  },
  "agents": {
    "overrides": {
      "cli_help": {
        "modelConfig": {
          "model": "gemini-3-flash-preview"
        },
        "runConfig": {
          "maxTurns": 10
        }
      }
    }
  }
}